# ============================================================
# Divine Interior — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to source control.

# ─── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard
# → Select your project → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Live PHP Backend API (for production / Vercel deployment)
# Point this to your live server's API URL (e.g., cPanel, Hostinger, VPS)
# Leave blank or omit in local dev to automatically proxy to local XAMPP
VITE_API_BASE=https://your-domain.com/api

# ─── Shopify Storefront (already in code, move here optionally)
# VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
